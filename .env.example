# ---------------------------------------------------------------------------
# AI Citation Tracker — Environment Variables
# Copy this file to `.env` and fill in real values.
# ---------------------------------------------------------------------------

# PostgreSQL connection string used by Prisma.
# Local example:  postgresql://postgres:postgres@localhost:5432/ai_citation_tracker?schema=public
# Hosted (Neon/Supabase/Vercel Postgres) example includes ?sslmode=require
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/ai_citation_tracker?schema=public"

# SerpApi — Google AI Overview API
# Get a key at https://serpapi.com/manage-api-key
SERPAPI_API_KEY=""

# DataForSEO — Google Organic SERP API
# Credentials from https://app.dataforseo.com/api-access
DATAFORSEO_LOGIN=""
DATAFORSEO_PASSWORD=""

# Secret used to authorize the daily cron endpoint (/api/cron).
# Vercel Cron sends this as the Authorization: Bearer <secret> header.
# Generate any long random string.
CRON_SECRET=""
